generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AuthProvider {
  local
  google
}

enum UserRole {
  member
  admin
}

enum MembershipTier {
  member
  bronze
  silver
  gold
  diamond
}

enum VoucherTier {
  bronze
  silver
  gold
  diamond
}

enum DiscountType {
  percent
  fixed
}

enum FulfillmentType {
  delivery
  pickup
}

enum PaymentMethod {
  cash
  transfer
  card
}

enum PaymentStatus {
  pending
  paid
  failed
}

enum OrderStatus {
  pending
  confirmed
  processing
  ready
  delivered
  cancelled
}

enum AnalyticsEventType {
  page_view
  click
  add_to_cart
  checkout_start
  purchase
}

model User {
  userId           String         @id @default(uuid()) @map("user_id") @db.Uuid
  email            String?        @unique @db.VarChar(255)
  phone            String?        @unique @db.VarChar(20)
  passwordHash     String?        @map("password_hash") @db.VarChar(255)
  fullName         String         @map("full_name") @db.VarChar(100)
  avatarUrl        String?        @map("avatar_url") @db.VarChar(500)
  authProvider     AuthProvider   @default(local) @map("auth_provider")
  googleId         String?        @unique @map("google_id") @db.VarChar(100)
  role             UserRole       @default(member)
  loyaltyPoints    Int            @default(0) @map("loyalty_points")
  membershipTier   MembershipTier @default(member) @map("membership_tier")
  isActive         Boolean        @default(false) @map("is_active")
  refreshTokenHash String?        @map("refresh_token_hash") @db.VarChar(255)
  otpHash          String?        @map("otp_hash") @db.VarChar(255)
  otpExpiresAt     DateTime?      @map("otp_expires_at")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  addresses        Address[]
  orders           Order[]
  reviews          Review[]
  loyaltyLogs      LoyaltyLog[]
  membershipCycles MembershipCycle[]
  analyticsEvents  AnalyticsEvent[]

  @@index([email])
  @@index([phone])
  @@map("users")
}

model Address {
  addressId     String   @id @default(uuid()) @map("address_id") @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  recipientName String   @map("recipient_name") @db.VarChar(100)
  phone         String   @db.VarChar(20)
  street        String   @db.VarChar(255)
  district      String   @db.VarChar(100)
  city          String   @db.VarChar(100)
  isDefault     Boolean  @default(false) @map("is_default")
  createdAt     DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@index([userId])
  @@map("addresses")
}

model Category {
  categoryId  String   @id @default(uuid()) @map("category_id") @db.Uuid
  name        String   @db.VarChar(100)
  slug        String   @unique @db.VarChar(100)
  description String?
  imageUrl    String?  @map("image_url") @db.VarChar(500)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  products Product[]

  @@index([slug])
  @@map("categories")
}

model Product {
  productId      String   @id @default(uuid()) @map("product_id") @db.Uuid
  categoryId     String   @map("category_id") @db.Uuid
  name           String   @db.VarChar(255)
  slug           String   @unique @db.VarChar(255)
  description    String?
  basePrice      Decimal  @map("base_price") @db.Decimal(10, 2)
  thumbnailUrl   String?  @map("thumbnail_url") @db.VarChar(500)
  isCustomizable Boolean  @default(false) @map("is_customizable")
  avgRating      Decimal  @default(0) @map("avg_rating") @db.Decimal(3, 2)
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  category     Category       @relation(fields: [categoryId], references: [categoryId])
  images       ProductImage[]
  optionGroups OptionGroup[]
  orderItems   OrderItem[]

  @@index([categoryId])
  @@index([slug])
  @@map("products")
}

model ProductImage {
  imageId   String @id @default(uuid()) @map("image_id") @db.Uuid
  productId String @map("product_id") @db.Uuid
  imageUrl  String @map("image_url") @db.VarChar(500)
  sortOrder Int    @default(0) @map("sort_order")

  product Product @relation(fields: [productId], references: [productId], onDelete: Cascade)

  @@index([productId])
  @@map("product_images")
}

model OptionGroup {
  groupId    String  @id @default(uuid()) @map("group_id") @db.Uuid
  productId  String  @map("product_id") @db.Uuid
  name       String  @db.VarChar(100)
  isRequired Boolean @default(false) @map("is_required")
  isMultiple Boolean @default(false) @map("is_multiple")
  sortOrder  Int     @default(0) @map("sort_order")

  product Product      @relation(fields: [productId], references: [productId], onDelete: Cascade)
  items   OptionItem[]

  @@index([productId])
  @@map("option_groups")
}

model OptionItem {
  itemId     String  @id @default(uuid()) @map("item_id") @db.Uuid
  groupId    String  @map("group_id") @db.Uuid
  name       String  @db.VarChar(100)
  extraPrice Decimal @default(0) @map("extra_price") @db.Decimal(10, 2)
  imageUrl   String? @map("image_url") @db.VarChar(500)
  isActive   Boolean @default(true) @map("is_active")
  sortOrder  Int     @default(0) @map("sort_order")

  group            OptionGroup       @relation(fields: [groupId], references: [groupId], onDelete: Cascade)
  orderItemOptions OrderItemOption[]

  @@index([groupId])
  @@map("option_items")
}

model Coupon {
  couponId          String       @id @default(uuid()) @map("coupon_id") @db.Uuid
  code              String       @unique @db.VarChar(50)
  discountType      DiscountType @map("discount_type")
  discountValue     Decimal      @map("discount_value") @db.Decimal(10, 2)
  minOrderValue     Decimal      @default(0) @map("min_order_value") @db.Decimal(10, 2)
  maxDiscountAmount Decimal?     @map("max_discount_amount") @db.Decimal(10, 2)
  usageLimit        Int?         @map("usage_limit")
  usedCount         Int          @default(0) @map("used_count")
  startDate         DateTime     @map("start_date")
  endDate           DateTime     @map("end_date")
  isActive          Boolean      @default(true) @map("is_active")

  orders            Order[]
  vouchersInventory VoucherInventory[]

  @@index([code])
  @@map("coupons")
}

model Order {
  orderId             String          @id @default(uuid()) @map("order_id") @db.Uuid
  userId              String?         @map("user_id") @db.Uuid
  couponId            String?         @map("coupon_id") @db.Uuid
  recipientName       String          @map("recipient_name") @db.VarChar(100)
  phone               String          @db.VarChar(20)
  fulfillmentType     FulfillmentType @map("fulfillment_type")
  deliveryAddress     String?         @map("delivery_address")
  deliveryDate        DateTime        @map("delivery_date") @db.Date
  deliveryTimeSlot    String          @map("delivery_time_slot") @db.VarChar(50)
  subtotal            Decimal         @db.Decimal(10, 2)
  discountAmount      Decimal         @default(0) @map("discount_amount") @db.Decimal(10, 2)
  shippingFee         Decimal         @default(0) @map("shipping_fee") @db.Decimal(10, 2)
  totalAmount         Decimal         @map("total_amount") @db.Decimal(10, 2)
  paymentMethod       PaymentMethod   @map("payment_method")
  paymentStatus       PaymentStatus   @default(pending) @map("payment_status")
  orderStatus         OrderStatus     @default(pending) @map("order_status")
  note                String?
  cardType            String          @default("none") @map("card_type") @db.VarChar(30)
  cardMessage         String?         @map("card_message") @db.VarChar(300)
  loyaltyPointsEarned Int             @default(0) @map("loyalty_points_earned")
  loyaltyPointsUsed   Int             @default(0) @map("loyalty_points_used")
  createdAt           DateTime        @default(now()) @map("created_at")
  updatedAt           DateTime        @updatedAt @map("updated_at")

  user        User?        @relation(fields: [userId], references: [userId], onDelete: SetNull)
  coupon      Coupon?      @relation(fields: [couponId], references: [couponId], onDelete: SetNull)
  items       OrderItem[]
  loyaltyLogs LoyaltyLog[]

  @@index([userId])
  @@index([couponId])
  @@map("orders")
}

model OrderItem {
  orderItemId         String  @id @default(uuid()) @map("order_item_id") @db.Uuid
  orderId             String  @map("order_id") @db.Uuid
  productId           String  @map("product_id") @db.Uuid
  productNameSnapshot String  @map("product_name_snapshot") @db.VarChar(255)
  unitPriceSnapshot   Decimal @map("unit_price_snapshot") @db.Decimal(10, 2)
  quantity            Int
  isCustom            Boolean @default(false) @map("is_custom")
  customNote          String? @map("custom_note")
  itemTotal           Decimal @map("item_total") @db.Decimal(10, 2)

  order   Order             @relation(fields: [orderId], references: [orderId], onDelete: Cascade)
  product Product           @relation(fields: [productId], references: [productId])
  options OrderItemOption[]
  review  Review?

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model OrderItemOption {
  id                  String  @id @default(uuid()) @db.Uuid
  orderItemId         String  @map("order_item_id") @db.Uuid
  itemId              String  @map("item_id") @db.Uuid
  optionNameSnapshot  String  @map("option_name_snapshot") @db.VarChar(100)
  optionPriceSnapshot Decimal @map("option_price_snapshot") @db.Decimal(10, 2)

  orderItem OrderItem  @relation(fields: [orderItemId], references: [orderItemId], onDelete: Cascade)
  item      OptionItem @relation(fields: [itemId], references: [itemId])

  @@index([orderItemId])
  @@index([itemId])
  @@map("order_item_options")
}

model Review {
  reviewId    String   @id @default(uuid()) @map("review_id") @db.Uuid
  orderItemId String   @unique @map("order_item_id") @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  rating      Int
  comment     String?
  imageUrl    String?  @map("image_url") @db.VarChar(500)
  isVisible   Boolean  @default(true) @map("is_visible")
  createdAt   DateTime @default(now()) @map("created_at")

  orderItem OrderItem @relation(fields: [orderItemId], references: [orderItemId], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@index([userId])
  @@map("reviews")
}

model LoyaltyLog {
  logId       String   @id @default(uuid()) @map("log_id") @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  orderId     String   @map("order_id") @db.Uuid
  pointsDelta Int      @map("points_delta")
  reason      String   @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at")

  user  User  @relation(fields: [userId], references: [userId], onDelete: Cascade)
  order Order @relation(fields: [orderId], references: [orderId], onDelete: Cascade)

  @@index([userId])
  @@index([orderId])
  @@map("loyalty_logs")
}

model MembershipCycle {
  cycleId      String         @id @default(uuid()) @map("cycle_id") @db.Uuid
  userId       String         @map("user_id") @db.Uuid
  cycleStart   DateTime       @map("cycle_start") @db.Date
  cycleEnd     DateTime       @map("cycle_end") @db.Date
  totalOrders  Int            @map("total_orders")
  totalRevenue Decimal        @map("total_revenue") @db.Decimal(10, 2)
  tierResult   MembershipTier @map("tier_result")
  createdAt    DateTime       @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@index([userId])
  @@index([cycleStart, cycleEnd])
  @@map("membership_cycles")
}

model VoucherInventory {
  voucherTemplateId String      @id @default(uuid()) @map("voucher_template_id") @db.Uuid
  tier              VoucherTier
  couponId          String      @map("coupon_id") @db.Uuid
  quantityPerMonth  Int         @map("quantity_per_month")
  isActive          Boolean     @default(true) @map("is_active")

  coupon Coupon @relation(fields: [couponId], references: [couponId], onDelete: Cascade)

  @@index([tier])
  @@index([couponId])
  @@map("vouchers_inventory")
}

model AnalyticsEvent {
  eventId     String             @id @default(uuid()) @map("event_id") @db.Uuid
  sessionId   String             @map("session_id") @db.VarChar(100)
  userId      String?            @map("user_id") @db.Uuid
  eventType   AnalyticsEventType @map("event_type")
  pageUrl     String             @map("page_url") @db.VarChar(500)
  referrer    String?            @db.VarChar(500)
  deviceType  String             @map("device_type") @db.VarChar(50)
  os          String             @db.VarChar(50)
  browser     String             @db.VarChar(50)
  utmSource   String?            @map("utm_source") @db.VarChar(100)
  utmMedium   String?            @map("utm_medium") @db.VarChar(100)
  utmCampaign String?            @map("utm_campaign") @db.VarChar(100)
  meta        Json?
  createdAt   DateTime           @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [userId], onDelete: SetNull)

  @@index([sessionId])
  @@index([userId])
  @@map("analytics_events")
}

model Banner {
  bannerId  String   @id @default(uuid()) @map("banner_id") @db.Uuid
  title     String   @db.VarChar(255)
  subtitle  String?  @db.VarChar(500)
  imageUrl  String   @map("image_url") @db.VarChar(500)
  linkUrl   String?  @map("link_url") @db.VarChar(500)
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([isActive, sortOrder])
  @@map("banners")
}
