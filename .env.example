# Server
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/weebee"

# Redis
REDIS_URL="redis://localhost:6379"

# CORS (cho phép nhiều origin, cách nhau bằng dấu phẩy)
FRONTEND_URL="http://localhost:4200,https://yourdomain.com"

# JWT
JWT_ACCESS_SECRET="replace_with_at_least_32_characters_access_secret"
JWT_REFRESH_SECRET="replace_with_at_least_32_characters_refresh_secret"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Google OAuth
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"
GOOGLE_CALLBACK_URL="http://localhost:3000/auth/google/callback,https://api.yourdomain.com/auth/google/callback"

# Cloudinary
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# Nodemailer (Gmail SMTP)
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT="587"
EMAIL_USER="your_email@gmail.com"
EMAIL_PASS="your_app_password"

# Twilio
TWILIO_ACCOUNT_SID="your_account_sid"
TWILIO_AUTH_TOKEN="your_auth_token"
TWILIO_PHONE_NUMBER="+1234567890"

# QR chuyển khoản tĩnh (URL ảnh QR ngân hàng cố định)
STATIC_QR_URL="https://res.cloudinary.com/your_cloud/image/upload/your_qr.png"

# Internal endpoints (optional locally, recommended in production)
INTERNAL_API_KEY="replace_with_at_least_16_characters"
