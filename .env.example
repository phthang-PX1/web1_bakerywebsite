# Server
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/weebee"

# Redis
REDIS_URL="redis://localhost:6379"

# CORS (cho phép nhiều origin, cách nhau bằng dấu phẩy)
FRONTEND_URL="http://localhost:4200,https://yourdomain.com"

# Google OAuth
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"
GOOGLE_CALLBACK_URL="http://localhost:3000/auth/google/callback,https://api.yourdomain.com/auth/google/callback"

# Cloudinary
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# Nodemailer (Gmail SMTP)
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT="587"
EMAIL_USER="your_email@gmail.com"
EMAIL_PASS="your_app_password"

# Twilio
TWILIO_ACCOUNT_SID="your_account_sid"
TWILIO_AUTH_TOKEN="your_auth_token"
TWILIO_PHONE_NUMBER="+1234567890"

# Sepay
SEPAY_API_KEY="your_sepay_api_key"               # Lấy từ my.sepay.vn -> Tích hợp Webhooks
SEPAY_MERCHANT_ID="your_merchant_id"             # (nếu cần, hiện tại chưa dùng)
SEPAY_ACCOUNT_NUMBER="0123499999"                # Số tài khoản ngân hàng của bạn
SEPAY_BANK_CODE="MBBank"                         # Mã ngân hàng (VD: MBBank, Vietcombank)
SEPAY_WEBHOOK_SECRET="your_webhook_secret"       # Dùng để xác thực webhook (API Key)
SEPAY_QR_TEMPLATE="compact"                      # compact / qronly / (để trống)

# Static QR (fallback nếu Sepay lỗi, không bắt buộc)
STATIC_QR_URL=""